{
  "http.proxyStrictSSL": false,
  "python.jediEnabled": false,
  "inlayHint.enable": false,
  "pyright.python.linting.ruffEnabled": true,
  "pyright.inlayHints.variableTypes": false,
  "python.autoUpdateLanguageServer": true,
  "python.pythonPath": "~/.config/coc/python",
  "python.venvFolders": ["~/venvs"],
  "python.venvPath": "~/venvs",
  "python.linting.pylintEnabled": false,
  "python.linting.flake8Enabled": false,
  "coc.preferences.diagnostic.displayByAle": true,
  "coc.disable_filetypes": ["tex"],
  "languageserver": {
    "go": {
      "command": "gopls",
      "rootPatterns": ["go.mod"],
      "trace.server": "verbose",
      "filetypes": ["go"]
    },
  },
  "svelte.enable-ts-plugin": false
}
